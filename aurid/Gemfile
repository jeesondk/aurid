# Aurid Shared Gemfile
# This is the base Gemfile that all Rails apps inherit from

source "https://rubygems.org"

# Ruby version
ruby "3.2.2"

# Shared gems for all Aurid Rails applications
gem "rails", "~> 7.1"
gem "pg", "~> 1.5"
gem "redis", "~> 5.0"
gem "sidekiq", "~> 7.0"
gem "connection_pool", "~> 2.4"
gem "puma", "~> 6.4"

# Authentication and Authorization
gem "devise", "~> 4.9"
gem "devise-jwt", "~> 0.6"
gem "doorkeeper", "~> 5.6" # OAuth2 provider

# API
gem "jbuilder", "~> 2.11"
gem "jsonapi-serializer", "~> 2.2"
gem "rack-cors", "~> 2.0"

# Background jobs
gem "good_job", "~> 3.0" # Alternative to Sidekiq

# Security
gem "rack-attack", "~> 6.7"
gem "brakeman", "~> 6.0", require: false
gem "securerandom", "~> 0.1"

# Monitoring and Logging
gem "lograge", "~> 0.14"
gem "sentry-rails", "~> 5.0"
gem "sentry-ruby", "~> 5.0"
gem "prometheus_exporter", "~> 0.5"

# Testing
gem "rspec-rails", "~> 6.0"
gem "factory_bot_rails", "~> 6.4"
gem "faker", "~> 3.2"
gem "shoulda-matchers", "~> 6.0"
gem "timecop", "~> 0.9"

# Development and Debugging
gem "pry-rails", "~> 0.3.9"
gem "better_errors", "~> 2.9"
gem "binding_of_caller", "~> 1.0"
gem "annotate", "~> 3.2", require: false

# Keycloak integration
gem "ruby-keycloak", "~> 4.0"
gem "omniauth-keycloak", "~> 0.2"

# FreeIPA/LDAP integration
gem "net-ldap", "~> 0.16"
gem "ruby-freeipa", "~> 0.5"

# Health checks
gem "health_check", "~> 3.2"

# Configuration
gem "dotenv-rails", "~> 3.0"
gem "config", "~> 3.0"

# Internationalization
gem "i18n", "~> 1.14"

# File processing
gem "activestorage", "~> 7.1"
gem "mini_magick", "~> 4.12"

# Database
gem "activerecord-import", "~> 1.5"
gem "pg_search", "~> 2.4"

# Caching
gem "redis-rails", "~> 5.0"
gem "dalli", "~> 3.2"

# Webpack / JavaScript
gem "jsbundling-rails", "~> 1.3"
gem "cssbundling-rails", "~> 1.3"
gem "stimulus-rails", "~> 1.3"

# Types
gem "sorbet", "~> 0.5", require: false
gem "sorbet-rails", "~> 0.8", require: false
gem "tapioca", "~> 0.7", require: false

# Group by environment
group :development, :test do
  gem "byebug", "~> 11.1", platforms: [:mri, :mingw, :x64_mingw]
  gem "rubocop", "~> 1.56", require: false
  gem "rubocop-rails", "~> 2.21", require: false
  gem "rubocop-rspec", "~> 2.22", require: false
  gem "standard", "~> 1.1", require: false
end

group :test do
  gem "capybara", "~> 3.39"
  gem "cuprite", "~> 2.0"
  gem "webmock", "~> 3.19"
  gem "vcr", "~> 6.2"
end

group :production do
  gem "rails_12factor", "~> 1.1"
end
